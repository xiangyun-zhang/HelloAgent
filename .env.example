# ==========================================
# 大模型 API 配置
# ==========================================
AGENT_API_KEY=your_api_key_here
AGENT_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
AGENT_MODEL=glm-4-flash

# ==========================================
# 助手显示配置
# ==========================================
# 这里配置的名字只用于命令行界面的打印展示
AGENT_NAME=Assistant

# 对话记忆保留轮数（防止超出Token限制，建议 5~20）
MAX_HISTORY_ROUNDS=10